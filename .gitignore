## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file for .NET is based on:
## https://raw.githubusercontent.com/github/gitignore/main/VisualStudio.gitignore

# [Visual Studio]
.vs/
*.user
*.userosscache
*.sln.docstates

# [Build results]
[Bb]in/
[Oo]bj/
[Ll]og/
[Tt]est[Rr]esults/

# [NuGet]
packages/
*.nupkg
# NuGet Restore
project.lock.json
project.assets.json

# [User-specific files]
*.suo
*.user
*.userosscache
*.sln.docstates
*.patch
*.diff

# [VS Code]
.vscode/
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace

# [Database]
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# [OS generated files]
.DS_Store
Thumbs.db

# [Environment Variables]
.env
.env.*
